{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(type *)",
      "Bash(file *)",
      "Bash(wc *)",
      "Bash(tree *)",
      "Bash(stat *)",
      "Bash(uname *)",
      "Bash(whoami)",
      "Bash(realpath *)",
      "Bash(readlink *)",
      "Bash(du *)",
      "Bash(diff *)",
      "Bash(gh *)",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.!(example))",
      "Read(**/secrets/**)",
      "Read(**/credentials*)",
      "Read(**/.ssh/**)",
      "Read(**/.gnupg/**)",
      "Read(**/.aws/credentials)",
      "Read(**/.npmrc)",
      "Read(**/.pypirc)",
      "Read(**/.netrc)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.keystore)",
      "Edit(**/.env)",
      "Edit(**/.env.!(example))",
      "Edit(**/secrets/**)",
      "Edit(**/credentials*)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Edit(**/*.p12)",
      "Edit(**/*.pfx)",
      "Edit(**/*.keystore)",
      "Write(**/.env)",
      "Write(**/.env.!(example))",
      "Write(**/secrets/**)",
      "Write(**/credentials*)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Edit(~/.bash_profile)",
      "Edit(~/.zprofile)",
      "Edit(//etc/**)",
      "Edit(//usr/**)",
      "Edit(//bin/**)",
      "Edit(//sbin/**)",
      "Bash(git push * --force *)",
      "Bash(git push --force *)",
      "Bash(git push * -f *)",
      "Bash(git push -f *)",
      "Bash(git push origin main)",
      "Bash(git push origin main *)",
      "Bash(git push origin master)",
      "Bash(git push origin master *)",
      "Bash(git push origin develop)",
      "Bash(git push origin develop *)",
      "Bash(git push * origin main)",
      "Bash(git push * origin main *)",
      "Bash(git push * origin master)",
      "Bash(git push * origin master *)",
      "Bash(git push * origin develop)",
      "Bash(git push * origin develop *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(rm -rf *)"
    ],
    "ask": [
      "Bash(git checkout .)",
      "Bash(git restore .)"
    ],
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/satoshi-onga/.claude/statusline.sh"
  },
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/satoshi-onga/Documents/onclimb-industries/.claude/skills/jarvis-worklog/bin/collect.sh >> /Users/satoshi-onga/Documents/onclimb-industries/worklog-data/logs/collect-hook.log 2>&1",
            "timeout": 120,
            "statusMessage": "worklog: collecting session logs"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "language": "japanese",
  "tui": "fullscreen",
  "voice": {
    "enabled": false,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true,
  "theme": "auto",
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": false,
  "model": "opus[1m]"
}
